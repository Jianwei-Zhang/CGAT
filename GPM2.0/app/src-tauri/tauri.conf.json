{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPM Next",
  "version": "0.1.0",
  "identifier": "com.gpm.next",
  "build": {
    "beforeDevCommand": {
      "cwd": "../frontend",
      "script": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5174"
    },
    "beforeBuildCommand": {
      "cwd": "../frontend",
      "script": "node ./node_modules/vite/bin/vite.js build"
    },
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "GPM Next",
        "width": 1360,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
